# Copy to .env.development (dev) or .env.production (prod) and fill in values.
# VITE_API_URL must include the API prefix configured in auth_user_service (API_PREFIX).

# Full URL to the API including prefix, e.g.:
#   local dev:  http://localhost:8000/api/v1
#   TLS proxy:  https://localhost:4430/api/v1
#   production: https://auth.your-domain.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Backend origin (without path) — used as __BACKEND_ORIGIN__ compile-time constant.
# Must match host_permissions and connect-src in manifest.json.
VITE_BACKEND_ORIGIN=http://localhost:8000
