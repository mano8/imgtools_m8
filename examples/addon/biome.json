{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "warn"
      },
      "correctness": {
        "useJsxKeyInIterable": "error",
        "useExhaustiveDependencies": "warn"
      },
      "nursery": {
        "useImportType": "info",
        "useQwikValidLexicalScope": "off",
        "noImgElement": "off",
        "useImageSize": "off"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useNodejsImportProtocol": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "jsx": {
        "noReactSpecificProps": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 88
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "package-lock.json"
    ]
  }
}
