# local envs
# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and aqcuire TLS certificates
DOMAIN="localhost"
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

# Environment: local, staging, production
ENVIRONMENT="local"

API_PREFIX="/fastapi"
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true
PROJECT_NAME="M8App"
STACK_NAME="full-stack-m8-app"

# Static Path
STATIC_BASE_PATH="changethis"
TEMPLATES_BASE_PATH="changethis"

# Google OAuth
GOOGLE_CLIENT_ID="changethis"
GOOGLE_CLIENT_SECRET="changethis"
# Google OAuth Redirect URI
# This is the URL that Google will redirect to after authentication
# It should match the URL of your frontend application
# For local development, it might look like this:
# http://localhost:5173/auth/callback
#GOOGLE_REDIRECT_URI="http://localhost:5173/auth/callback"
# Google OAuth Scopes
# These are the scopes that your application will request from Google
# You can adjust these based on your application's needs
#GOOGLE_SCOPES="openid email profile"
# Google OAuth Token URL
# This is the URL that your application will use to exchange the authorization code for an access token
# It should match the URL of your Google OAuth provider
# For local development, it might look like this:
# https://oauth2.googleapis.com/token

# Backend
# Used by the auth_user_service to generate links in emails to the frontend
BACKEND_HOST="http://127.0.0.1:9000"
FRONTEND_HOST="http://localhost:5173"
EXTENSION_ID="changethis"
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
SECRET_KEY="changethis"
ACCESS_SECRET_KEY="changethis"
REFRESH_SECRET_KEY="changethis"
TOKEN_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=3600
# Must match auth_user_service TOKEN_MODE exactly.
# stateless | hybrid | stateful (default)
TOKEN_MODE="stateful"
# Must match auth_user_service TOKEN_ISSUER / TOKEN_AUDIENCE exactly.
# Leave commented to skip claim enforcement (backward-compatible default).
#TOKEN_ISSUER="https://auth.example.com"
#TOKEN_AUDIENCE="https://api.example.com"

FIRST_SUPERUSER="changethis"
FIRST_SUPERUSER_PASSWORD="changethis"

# Mysql
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_DATABASE="m8_app"
DB_USER="changethis"
DB_PASSWORD="changethis"

# Redis
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_USER="appuser"
REDIS_PASSWORD="changethis"

# Observability — Prometheus metrics
# Master switch. When false the /metrics endpoint is not registered and there
# is zero runtime overhead. Default: false
#METRICS_ENABLED=false
# Which metric groups to collect. Comma-separated list or "all".
# Valid values: all | traffic | performance | reliability | health
# Examples:
#   METRICS_GROUPS="all"
#   METRICS_GROUPS="traffic,performance"
#   METRICS_GROUPS="reliability,health"
# Default: "all" (only matters when METRICS_ENABLED=true)
#METRICS_GROUPS="all"