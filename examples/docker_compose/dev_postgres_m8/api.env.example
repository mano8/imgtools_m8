# Copy to api.env and replace every "changethis" with real values.
# Does NOT include auth-service-only secrets (FIRST_SUPERUSER, PRIVATE_API_SECRET,
# TOKENS_ENCRYPTION_KEY, ACCESS_PRIVATE_KEY_FILE).

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=M8FastApi
STACK_NAME=m8-fastapi-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/fastapi
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── Service paths ─────────────────────────────────────────────────────────────
STATIC_BASE_PATH=/opt/fastapi_service/app/static
TEMPLATES_BASE_PATH=/opt/fastapi_service/app/templates

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=changethis
DB_USER=changethis
DB_PASSWORD=changethis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_USER=appuser
REDIS_PASSWORD=changethis

# ── Token verification — HS256 (shared key; no auth-service secrets here) ─────
ACCESS_SECRET_KEY=changethis
REFRESH_SECRET_KEY=changethis
ACCESS_TOKEN_ALGORITHM=HS256
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=3600

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=false
METRICS_GROUPS=all
