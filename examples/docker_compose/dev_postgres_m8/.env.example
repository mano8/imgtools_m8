# Copy to .env — Docker Compose infrastructure variables only.
# Application settings go in auth.env and api.env (see *.example files there).
# Generate passwords: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Optional: Traefik port binding ───────────────────────────────────────────
# Default 127.0.0.1 (localhost only). Set to 0.0.0.0 to expose on the LAN.
#API_BIND_IP=127.0.0.1

# ── PostgreSQL container init ─────────────────────────────────────────────────
DB_DATABASE=changethis_db
DB_USER=changethis_user
DB_PASSWORD=changethis_password
DB_PORT=5432

# ── Redis container init ──────────────────────────────────────────────────────
REDIS_PASSWORD=changethis_redis_password
