# .env.prod_example — Example .env for production with an external Vault deployment.
#
# Key differences from .env.example (which uses the bundled dev-mode Vault):
#
#   ✗ VAULT_DEV_TOKEN    — removed entirely. No Vault container in this compose.
#   ✗ AUTH_DB_PASSWORD   — removed. Your secrets pipeline pre-populates Vault;
#                           auth_user_service reads DB_PASSWORD from Vault, not .env.
#
# What remains in .env:
#   - PostgreSQL superuser bootstrap (required if postgres runs in this compose).
#   - API service DB credentials (fastapi_service has no Vault integration).
#   - REDIS_PASSWORD for the redis_cache container startup command and for api.env.
#
# Inject all remaining secrets via CI/CD (GitHub Actions secrets, GitLab CI
# variables, etc.) — do not commit real values to version control.
#
# For a fully secrets-free .env, pre-provision the database externally (managed
# DB like RDS, Cloud SQL, or Supabase) and use a managed Redis (Elasticache,
# Upstash). Then remove the DB block below entirely.

# ── Optional: Traefik port binding ───────────────────────────────────────────
# Default 127.0.0.1 (localhost only). Set to 0.0.0.0 to expose on the LAN.
#API_BIND_IP=0.0.0.0

# ── PostgreSQL superuser (engine bootstrap) ───────────────────────────────────
# Required only if postgres runs in this compose. For a managed DB, remove this
# block and set DB_HOST in auth.env / api.env to your managed DB hostname.
# Inject via CI/CD — do not commit real values.
DB_USER=m8_admin
DB_PASSWORD=<inject-via-cicd>
DB_PORT=5432

# ── DB isolation: per-service users ───────────────────────────────────────────
# AUTH_DB_PASSWORD is intentionally absent.
# It is stored in your external Vault and written there by your secrets pipeline.
# auth_user_service reads DB_PASSWORD from Vault at startup — never from .env.
AUTH_DB_USER=auth_user
AUTH_DB_NAME=auth_db

# fastapi_service has no Vault integration — its DB password stays here.
# Inject via CI/CD.
API_DB_USER=api_user
API_DB_PASSWORD=<inject-via-cicd>
API_DB_NAME=api_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for the redis_cache container startup command.
# Also stored in your external Vault so auth_user_service never reads it from .env.
# Inject via CI/CD.
REDIS_PASSWORD=<inject-via-cicd>
