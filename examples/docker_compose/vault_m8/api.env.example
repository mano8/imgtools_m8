# Copy to api.env and replace every "changethis" with real values.
# The consumer service (fastapi_service) does NOT use Vault — its secrets are
# provided directly via this env file. Only the auth_user_service (issuer) uses Vault.
# Token verification uses JWKS — no private key or ACCESS_SECRET_KEY needed.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=M8FastApi
STACK_NAME=m8-fastapi-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/fastapi
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_USER must match API_DB_USER in .env; DB_PASSWORD must match API_DB_PASSWORD.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=api_db
DB_USER=changethis_api_user
DB_PASSWORD=changethis_api_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_USER=appuser
REDIS_PASSWORD=changethis_redis_password

# ── Token verification — RS256 via JWKS ──────────────────────────────────────
ACCESS_TOKEN_ALGORITHM=RS256
JWKS_URI=http://auth_user_service:8000/user/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=300
REFRESH_SECRET_KEY=changethis_min32chars_mixedCase_digit_hyphen
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all
