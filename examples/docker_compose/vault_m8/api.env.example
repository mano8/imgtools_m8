# Copy to api.env and replace every "changethis" with real values.
# The consumer service (fastapi_full) does NOT use Vault — its secrets are
# provided directly via this env file. Only the auth_user_service (issuer) uses Vault.
# Token verification uses JWKS — no private key or ACCESS_SECRET_KEY needed.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=M8FastApi
STACK_NAME=m8-fastapi-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/fastapi
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_USER must match API_DB_USER in .env; DB_PASSWORD must match API_DB_PASSWORD.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=api_db
DB_USER=changethis_api_user
DB_PASSWORD=changethis_api_password

# ── Token verification — RS256 via JWKS ──────────────────────────────────────
ACCESS_TOKEN_ALGORITHM=RS256
JWKS_URI=http://auth_user_service:8000/user/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=300
REFRESH_SECRET_KEY=changethis_min32chars_mixedCase_digit_hyphen
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token boundary claims (recommended for production) ────────────────────────
# Must match auth_user_service TOKEN_ISSUER / TOKEN_AUDIENCE exactly.
# When set, tokens with a different iss or aud claim are rejected.
#TOKEN_ISSUER=https://auth.example.com
#TOKEN_AUDIENCE=https://api.example.com

# ── Token revocation (stateful mode) ──────────────────────────────────────────
# Must match auth_user_service PRIVATE_API_SECRET. Auth Redis stays private to
# auth_user_service — consumer calls this HTTP endpoint instead.
INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
PRIVATE_API_SECRET=changethis_redis_password

# ── Auth degradation policy (failure-mode matrix) ────────────────────────────
# Default posture: fail_closed for revocation, session writes, and refresh
# validation; fail_open for rate limiting. All overridable per-control.
#
# Availability-first: accept requests when revocation check is unavailable
#ACCESS_REVOCATION_FAILURE_MODE=fail_open
#
# High-security: force all controls closed regardless of per-control settings
#AUTH_STRICT_MODE=true
#
# Per-control overrides (uncomment as needed)
#REFRESH_VALIDATION_FAILURE_MODE=fail_closed
#SESSION_WRITE_FAILURE_MODE=fail_closed
#RATE_LIMIT_FAILURE_MODE=fail_open


# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all
