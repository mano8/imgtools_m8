# Copy to .env — Docker Compose infrastructure + Vault bootstrap variables.
# Application settings go in auth.env and api.env (see *.example files there).
# Generate passwords: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Optional: Traefik port binding ───────────────────────────────────────────
# Default 127.0.0.1 (localhost only). Set to 0.0.0.0 to expose on the LAN.
#API_BIND_IP=127.0.0.1

# ── PostgreSQL superuser (engine bootstrap) ───────────────────────────────────
# Used by the postgres container itself + init-db.sh to create per-service users.
# Do not use these credentials in auth.env / api.env — services get their own users.
DB_USER=m8_admin
DB_PASSWORD=changethis_pg_root_password
DB_PORT=5432

# ── DB isolation: choose ONE model, comment out the others ───────────────────
#
# SCENARIO 1 — single shared database
#   All services share one DB and one user. Simplest setup; no data isolation.
#
# DB_USER=myuser
# DB_PASSWORD=changethis_min12chars
# DB_NAME=myapp
#
# SCENARIO 2 — per-service isolation (default for this stack)
#   init-db.sh creates a separate DB + user per service on first volume init.
#   Prefix rules: UPPERCASE, starts with a letter, chars [A-Z0-9_].
#
AUTH_DB_USER=changethis_auth_user
AUTH_DB_PASSWORD=changethis_auth_password   # ← also written to Vault as DB_PASSWORD for auth_user_service
AUTH_DB_NAME=auth_db

API_DB_USER=changethis_api_user
API_DB_PASSWORD=changethis_api_password
API_DB_NAME=api_db
#
# SCENARIO 3 — arbitrary N-service isolation
#   Add any PREFIX_DB_{USER,PASSWORD,NAME} triplet. No compose edits needed.
#
# WORKER_DB_USER=worker_user
# WORKER_DB_PASSWORD=changethis_min12chars
# WORKER_DB_NAME=worker_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changethis_redis_password    # ← also written to Vault as REDIS_PASSWORD

# ── HashiCorp Vault (dev mode) ────────────────────────────────────────────────
# Root token for the local Vault dev server.
# Generate a UUID: python -c "import uuid; print(uuid.uuid4())"
# This token is used to:
#   1. Start Vault with a predictable root token (VAULT_DEV_ROOT_TOKEN_ID)
#   2. Allow vault_init to write secrets into Vault
#   3. Allow auth_user_service to read secrets from Vault (injected via compose environment)
#
# WARNING: dev mode stores secrets in-memory. On Vault container restart, secrets
# are wiped. Re-populate with: docker compose start vault_init
# For production, use server mode with file/raft storage and a scoped app token.
VAULT_DEV_TOKEN=changethis-replace-with-a-uuid

# ── Secrets & CI ──────────────────────────────────────────────────────────────
# .env must be fully written BEFORE 'docker compose up' on first boot.
# init-db.sh runs once at volume creation — changes to .env do not reprovision.
# To reprovision after config changes: bash init.sh --reset-db
#
# CI integration tests (clean state between runs):
#   bash init.sh --reset-db --yes && docker compose up -d --build
