# Copy to .env and replace "changethis" with real values.
# Auto-loaded by docker-compose for ${VAR} substitution and injected into
# services via the environment: block.
# Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Generate RS256 keys:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem

DOMAIN="localhost"
ENVIRONMENT="local"
PROJECT_NAME="M8AsymApp"
STACK_NAME="asymmetric-m8-app"

BACKEND_HOST="http://127.0.0.1:9000"
FRONTEND_HOST="http://localhost:5173"

# Prefix consumers use to reach auth_user_service
AUTH_PREFIX="/user"

FIRST_SUPERUSER="changethis@example.com"
FIRST_SUPERUSER_PASSWORD="changethis"

# Token signing — RS256 asymmetric
# ACCESS_SECRET_KEY is intentionally absent (HS256 only).
ACCESS_TOKEN_ALGORITHM="RS256"
REFRESH_TOKEN_ALGORITHM="HS256"
# Stable key ID embedded in JWT kid header — must match across auth + consumer
ACCESS_KEY_ID="changethis"
# Refresh tokens remain symmetric
REFRESH_SECRET_KEY="changethis"
# stateless | hybrid | stateful
TOKEN_MODE="stateful"

#GOOGLE_CLIENT_ID="changethis"
#GOOGLE_CLIENT_SECRET="changethis"

# Database — MySQL
SELECTED_DB="Mysql"
DB_HOST="m8_db"
DB_PORT=3306
DB_DATABASE="m8_asym_app"
DB_USER="changethis"
DB_PASSWORD="changethis"
DB_ROOT_PASSWORD="changethis"

# Redis
REDIS_HOST="redis_cache"
REDIS_PORT=6379
REDIS_USER="appuser"
REDIS_PASSWORD="changethis"
