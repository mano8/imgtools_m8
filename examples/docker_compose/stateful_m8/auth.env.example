# Copy to auth.env — auth_user_service complete configuration.
# Generate secret keys (32+ chars, mixed-case + digit + hyphen/underscore):
#   python -c "import secrets,string; a=string.ascii_letters+string.digits+'-_'; print(''.join(secrets.choice(a) for _ in range(64)))"

DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=MyAuthService
STACK_NAME=my-auth-service

API_PREFIX=/user
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

STATIC_BASE_PATH=/opt/auth_user_service/app/static
TEMPLATES_BASE_PATH=/opt/auth_user_service/app/templates

BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000

AUTH_SERVICE_ROLE=issuer

SELECTED_DB=Mysql
DB_HOST=m8_db
DB_PORT=3306
DB_DATABASE=auth_db
DB_USER=changethis_auth_user
DB_PASSWORD=changethis_auth_password

REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_USER=appuser
REDIS_PASSWORD=changethis_redis_password
#REDIS_SSL=false

ACCESS_TOKEN_ALGORITHM=HS256
REFRESH_TOKEN_ALGORITHM=HS256
ACCESS_SECRET_KEY=changethis_min32chars_mixedCase_digit_hyphen
REFRESH_SECRET_KEY=changethis_min32chars_mixedCase_digit_hyphen
#REFRESH_SECRET_KEY_OLD=
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=3600

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis_Strong1!
PRIVATE_API_SECRET=changethis_min32chars_mixedCase_digit_hyphen
TOKENS_ENCRYPTION_KEY=changethis_min32chars_mixedCase_digit_hyphen

# ── Auth degradation policy (optional) ────────────────────────────────────────
# Controls behaviour when Redis is unavailable. Defaults shown.
# fail_open: allow through.  fail_closed: return 503.
# AUTH_STRICT_MODE=true overrides all per-control modes to fail_closed.
#AUTH_STRICT_MODE=false
#REFRESH_VALIDATION_FAILURE_MODE=fail_closed
#SESSION_WRITE_FAILURE_MODE=fail_closed
#RATE_LIMIT_FAILURE_MODE=fail_open
#ACCESS_REVOCATION_FAILURE_MODE=fail_open

METRICS_ENABLED=false
METRICS_GROUPS=all

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
