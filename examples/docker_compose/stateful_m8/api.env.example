# Copy to api.env and replace "changethis" with real values.
# Shared config (DB, Redis credentials, token secrets/algorithms) is injected
# from .env via the docker-compose environment: block — no need to repeat it here.
# Only service-specific vars below are required.
# For standalone (non-compose) deployment, add shared vars from .env here too.

# ── API & docs ──────────────────────────────────────────────────────────────────
API_PREFIX="/fastapi"
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── Service paths ───────────────────────────────────────────────────────────────
STATIC_BASE_PATH="/opt/fastapi_service/app/static"
TEMPLATES_BASE_PATH="/opt/fastapi_service/app/templates"

# ── CORS ────────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173"

# ── Service role ────────────────────────────────────────────────────────────────
AUTH_SERVICE_ROLE="consumer"

# ── Token expiry (not injected by compose) ──────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=3600

# ── Redis connection (host/port not injected by compose) ────────────────────────
REDIS_HOST="redis_cache"
REDIS_PORT=6379

# ── Observability ───────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS="all"
