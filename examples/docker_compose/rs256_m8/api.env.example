# Copy to api.env and replace every "changethis" with real values.
# Does NOT include auth-service-only secrets (FIRST_SUPERUSER, PRIVATE_API_SECRET,
# TOKENS_ENCRYPTION_KEY, ACCESS_PRIVATE_KEY_FILE, ACCESS_KEY_ID).
# Consumer verifies access tokens via JWKS — no private key or ACCESS_SECRET_KEY needed.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=M8FastApi
STACK_NAME=m8-fastapi-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/fastapi
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (MariaDB) ────────────────────────────────────────────────────────
SELECTED_DB=Mysql
DB_HOST=m8_db
DB_PORT=3306
DB_DATABASE=api_db
DB_USER=changethis_api_user
DB_PASSWORD=changethis_api_password

# ── Token verification — RS256 via JWKS ──────────────────────────────────────
ACCESS_TOKEN_ALGORITHM=RS256
JWKS_URI=http://auth_user_service:8000/user/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=300
REFRESH_SECRET_KEY=changethis
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=hybrid
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token boundary claims (recommended for production) ────────────────────────
# Must match auth_user_service TOKEN_ISSUER / TOKEN_AUDIENCE exactly.
# When set, tokens with a different iss or aud claim are rejected.
#TOKEN_ISSUER=https://auth.example.com
#TOKEN_AUDIENCE=https://api.example.com

# ── Token revocation ───────────────────────────────────────────────────────────
# hybrid mode: access tokens are stateless (no revocation); not required.
# Switch TOKEN_MODE=stateful to enable full revocation via HTTP introspection:
# INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
# PRIVATE_API_SECRET=changethis

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=false
METRICS_GROUPS=all
