# Copy to .env — Docker Compose infrastructure variables only.
# Application settings go in auth.env and api.env (see *.example files there).
# Generate passwords: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Optional: Traefik port binding ───────────────────────────────────────────
# Default 127.0.0.1 (localhost only). Set to 0.0.0.0 to expose on the LAN.
#API_BIND_IP=127.0.0.1

# ── PostgreSQL engine bootstrap ───────────────────────────────────────────────
# DB_USER / DB_PASSWORD become the PostgreSQL superuser (POSTGRES_USER).
# Do not remove them — the engine container requires them.
# Note: for Scenario 1 (single DB), the superuser is also the app user.
DB_USER=changethis_admin
DB_PASSWORD=changethis_password
DB_PORT=5432

# ── DB isolation: choose ONE model, comment out the others ───────────────────
#
# SCENARIO 1 — single shared database
#   DB_USER above becomes the sole app user. DB_PASSWORD above is reused.
#   Add DB_NAME and remove Scenario 2 vars below.
#
# DB_NAME=myapp
#
# SCENARIO 2 — per-service isolation (default for this stack)
#   The superuser (DB_USER above) is used internally by init-db.sh to create
#   per-service users; services connect as AUTH_DB_USER / API_DB_USER only.
#   Prefix rules: UPPERCASE, starts with a letter, chars [A-Z0-9_].
#
AUTH_DB_USER=changethis_auth_user
AUTH_DB_PASSWORD=changethis_auth_password
AUTH_DB_NAME=auth_db

API_DB_USER=changethis_api_user
API_DB_PASSWORD=changethis_api_password
API_DB_NAME=api_db
#
# SCENARIO 3 — arbitrary N-service isolation
#   Add any PREFIX_DB_{USER,PASSWORD,NAME} triplet. No compose edits needed.
#
# WORKER_DB_USER=worker_user
# WORKER_DB_PASSWORD=changethis_min12chars
# WORKER_DB_NAME=worker_db

# ── Redis container init ──────────────────────────────────────────────────────
REDIS_PASSWORD=changethis_redis_password

# ── Secrets & CI ──────────────────────────────────────────────────────────────
# .env must be fully written BEFORE 'docker compose up' on first boot.
# init-db.sh runs once at volume creation — changes to .env do not reprovision.
# To reprovision after config changes: bash init.sh --reset-db
# Note: Prometheus/Grafana data in ./prometheus/data and ./grafana/data persists
# across --reset-db. Delete those directories manually to reset observability state.
#
# Secret managers (populate .env before compose):
#   vault kv get -format=json secret/myapp | jq -r 'to_entries[]|"\(.key)=\(.value)"' >> .env
#   infisical export --env=dev --format=dotenv > .env
#
# CI integration tests (clean state between runs):
#   bash init.sh --reset-db --yes && docker compose up -d --build
