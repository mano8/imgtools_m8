# Copy to auth.env and replace "changethis" with real values.
# Shared config (DB, Redis credentials, token algorithms, first-superuser) is
# injected from .env via the docker-compose environment: block — no need to
# repeat it here. Only service-specific vars below are required.
# For standalone (non-compose) deployment, add shared vars from .env here too.

# ── API & docs ──────────────────────────────────────────────────────────────────
API_PREFIX="/user"
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── Service paths ───────────────────────────────────────────────────────────────
STATIC_BASE_PATH="/opt/auth_user_service/app/static"
TEMPLATES_BASE_PATH="/opt/auth_user_service/app/templates"

# ── CORS ────────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173"

# ── Service role ────────────────────────────────────────────────────────────────
AUTH_SERVICE_ROLE="issuer"

# ── Auth secrets (fallback when compose does not inject them) ───────────────────
PRIVATE_API_SECRET="changethis"
TOKENS_ENCRYPTION_KEY="changethis"

# ── RS256 inline key material ───────────────────────────────────────────────────
# Paste PEM content with literal \n between lines (no actual newlines).
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Alternatively use ACCESS_PRIVATE_KEY_FILE / ACCESS_PUBLIC_KEY_FILE with a volume mount.
ACCESS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
ACCESS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Token expiry (not injected by compose) ──────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Redis connection (host/port not injected by compose) ────────────────────────
REDIS_HOST="redis_cache"
REDIS_PORT=6379

# ── Observability ───────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS="all"
