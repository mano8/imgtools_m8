# Docker build arguments for imgtools_m8
# Copy to .env, edit as needed, then:
#   set -a && source .env && set +a
#   docker build --build-arg OPENCV_VERSION --build-arg CUDA_ARCH_BIN .

# OpenCV version to build from source (must exist as a git tag on github.com/opencv/opencv)
OPENCV_VERSION=4.13.0

# CUDA compute capability of your GPU — leave empty to let CMake auto-detect (slower build).
# Look up your GPU at https://developer.nvidia.com/cuda-gpus
#   RTX 30xx (Ampere)   → 8.6
#   RTX 40xx (Ada)      → 8.9
#   RTX 50xx (Blackwell)→ 10.0
CUDA_ARCH_BIN=

# Optional: directory holding DNN upscaling models (.pb). Overrides the default user-cache
# location. Used for Docker / air-gapped / enterprise installs.
IMGTOOLS_M8_MODELS_DIR=changethis
